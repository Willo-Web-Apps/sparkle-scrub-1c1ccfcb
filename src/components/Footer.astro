---
const year = new Date().getFullYear();
---
<footer class="bg-surface-900 text-white pt-16 pb-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Top row -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-14">

      <!-- Brand column -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <span class="w-8 h-8 rounded-lg bg-brand-500 flex items-center justify-center font-extrabold text-surface-900 font-display text-sm">Z</span>
          <span class="text-lg font-extrabold tracking-tight font-display">Zestiq</span>
        </a>
        <p class="text-white/50 text-base leading-relaxed max-w-xs">
          Clean House. Happy Planet. Zero Drama.<br/>
          Nontoxic cleaning products with radical ingredient transparency.
        </p>
        <div class="flex gap-3 mt-6">
          <a href="#" aria-label="Instagram" class="w-9 h-9 rounded-lg bg-white/10 hover:bg-brand-500 hover:text-surface-900 flex items-center justify-center transition-colors text-white/60">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="#" aria-label="TikTok" class="w-9 h-9 rounded-lg bg-white/10 hover:bg-brand-500 hover:text-surface-900 flex items-center justify-center transition-colors text-white/60">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1-.06z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Products -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-white/40 mb-4">Products</h4>
        <ul class="space-y-2.5 text-sm text-white/60">
          <li><a href="#shop" class="hover:text-white transition-colors">All-Purpose Cleaner</a></li>
          <li><a href="#shop" class="hover:text-white transition-colors">Bathroom Scrub</a></li>
          <li><a href="#shop" class="hover:text-white transition-colors">Kitchen Degreaser</a></li>
          <li><a href="#shop" class="hover:text-white transition-colors">Glass &amp; Mirror Spray</a></li>
          <li><a href="#shop" class="hover:text-white transition-colors">Starter Bundle</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-white/40 mb-4">Company</h4>
        <ul class="space-y-2.5 text-sm text-white/60">
          <li><a href="/blog" class="hover:text-white transition-colors">Journal</a></li>
          <li><a href="#how-it-works" class="hover:text-white transition-colors">Our Ingredients</a></li>
          <li><a href="#cta" class="hover:text-white transition-colors">Our Promise</a></li>
          <li><a href="mailto:hello@zestiq.com" class="hover:text-white transition-colors">Contact Us</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom row -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <p class="text-xs text-white/30">&copy; {year} Zestiq. All rights reserved. Clean House. Happy Planet. Zero Drama.</p>
      <div class="flex gap-5 text-xs text-white/30">
        <a href="#" class="hover:text-white/60 transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white/60 transition-colors">Terms of Service</a>
        <a href="#" class="hover:text-white/60 transition-colors">Accessibility</a>
      </div>
    </div>

  </div>
</footer>
