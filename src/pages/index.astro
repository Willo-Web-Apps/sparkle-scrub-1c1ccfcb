---
import Base from '../layouts/Base.astro';
---
<Base
  title="Zestiq — Clean House. Happy Planet. Zero Drama."
  description="Zestiq makes nontoxic house cleaning products that are bold on grime and gentle on your family. Every ingredient listed. Zero exceptions."
>

  <!-- ═══════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════ -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden bg-surface-50">

    <!-- Decorative color blocks — flat, no gradient, Zestiq aesthetic -->
    <div class="absolute top-0 right-0 w-[420px] h-[420px] rounded-full translate-x-1/3 -translate-y-1/4 bg-brand-500 opacity-90 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[280px] h-[280px] rounded-full -translate-x-1/4 translate-y-1/3 bg-accent-500 opacity-80 pointer-events-none"></div>
    <div class="absolute top-1/2 right-[18%] w-[140px] h-[140px] rounded-full -translate-y-1/2 bg-green-500 opacity-70 pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-3xl">

        <!-- eyebrow -->
        <p class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-widest text-accent-500 animate-slide-up">
          <span class="w-8 h-0.5 bg-accent-500 rounded-full"></span>
          Nontoxic · Plant-Based · Radically Transparent
        </p>

        <!-- H1 -->
        <h1 class="mt-5 text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight text-surface-900 font-display leading-[1.05] animate-slide-up delay-100">
          Cleaning Products<br/>
          <span class="relative inline-block">
            <span class="relative z-10">That Don't Make&nbsp;You</span>
          </span><br/>
          <span class="text-accent-500">Choose Safety.</span>
        </h1>

        <!-- sub -->
        <p class="mt-6 text-xl md:text-2xl text-surface-800/70 max-w-xl leading-relaxed font-body animate-slide-up delay-200">
          Zestiq's nontoxic formulas are bold on grime, gentle on your family — every ingredient listed, zero exceptions.
        </p>

        <!-- CTA row -->
        <div class="mt-10 flex flex-col sm:flex-row items-start sm:items-center gap-4 animate-slide-up delay-300">
          <a
            href="#shop"
            class="inline-block px-8 py-4 bg-surface-900 text-white font-bold text-base rounded-xl hover:bg-surface-800 transition-colors"
          >
            Shop the Collection
          </a>
          <a
            href="#how-it-works"
            class="inline-block px-8 py-4 border-2 border-surface-900 text-surface-900 font-bold text-base rounded-xl hover:bg-surface-100 transition-colors"
          >
            See What's Inside →
          </a>
        </div>

        <!-- micro proof -->
        <p class="mt-5 text-sm text-surface-800/50 animate-slide-up delay-400">
          Free shipping on orders over $35 &nbsp;·&nbsp; Certified plant-based &nbsp;·&nbsp; 30-day happiness guarantee
        </p>
      </div>
    </div>

    <!-- floating pill badges — decorative -->
    <div class="hidden lg:block absolute bottom-16 right-12 animate-pop-in delay-500">
      <div class="flex flex-col gap-3">
        <div class="flex items-center gap-3 bg-white rounded-2xl px-5 py-3 shadow-lg border border-surface-200">
          <span class="text-2xl">🌿</span>
          <div>
            <p class="text-xs font-semibold text-surface-900 uppercase tracking-wide">100% Plant-Based</p>
            <p class="text-xs text-surface-800/50">No hidden chemicals</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-brand-500 rounded-2xl px-5 py-3 shadow-lg">
          <span class="text-2xl">🧪</span>
          <div>
            <p class="text-xs font-semibold text-surface-900 uppercase tracking-wide">Full Ingredient List</p>
            <p class="text-xs text-surface-900/60">Every bottle, always</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-accent-500 rounded-2xl px-5 py-3 shadow-lg">
          <span class="text-2xl">⭐</span>
          <div>
            <p class="text-xs font-semibold text-white uppercase tracking-wide">4.9 / 5 Stars</p>
            <p class="text-xs text-white/70">From 2,400+ customers</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       SOCIAL PROOF BAR
  ════════════════════════════════════════════════════ -->
  <section class="bg-surface-900 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="animate-slide-up">
          <p class="text-3xl md:text-4xl font-extrabold text-brand-500 font-display">40K+</p>
          <p class="mt-1 text-sm font-medium text-white/60 uppercase tracking-wider">Happy Homes</p>
        </div>
        <div class="animate-slide-up delay-100">
          <p class="text-3xl md:text-4xl font-extrabold text-brand-500 font-display">0</p>
          <p class="mt-1 text-sm font-medium text-white/60 uppercase tracking-wider">Toxic Chemicals</p>
        </div>
        <div class="animate-slide-up delay-200">
          <p class="text-3xl md:text-4xl font-extrabold text-brand-500 font-display">100%</p>
          <p class="mt-1 text-sm font-medium text-white/60 uppercase tracking-wider">Ingredient Transparency</p>
        </div>
        <div class="animate-slide-up delay-300">
          <p class="text-3xl md:text-4xl font-extrabold text-brand-500 font-display">4.9★</p>
          <p class="mt-1 text-sm font-medium text-white/60 uppercase tracking-wider">Average Review</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       THE PROBLEM (honest, direct, brand-voice)
  ════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center animate-slide-up">
        <p class="text-sm font-semibold uppercase tracking-widest text-green-500 mb-4">The Real Talk</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight text-surface-900 font-display leading-tight">
          Most cleaners hide<br/>
          <span class="text-accent-500">what's actually in them.</span>
        </h2>
        <p class="mt-6 text-lg text-surface-800/60 leading-relaxed">
          "Fragrance" can mean up to 3,000 undisclosed chemicals. "Natural" is unregulated marketing language. You deserve to know exactly what you're spraying around your kids, your pets, and your food.
          <strong class="text-surface-900"> Zestiq lists every ingredient. Full stop.</strong>
        </p>
      </div>

      <!-- 3-column comparison blocks -->
      <div class="mt-16 grid md:grid-cols-3 gap-6">
        <div class="rounded-2xl bg-surface-100 border border-surface-200 p-8 text-center animate-slide-up delay-100">
          <div class="text-4xl mb-4">😶</div>
          <h3 class="text-lg font-bold text-surface-900 font-display mb-2">Other Brands</h3>
          <p class="text-surface-800/60 text-base leading-relaxed">"Proprietary blend" hides ingredients. Scented with synthetic chemicals. Greenwashing everywhere.</p>
        </div>
        <div class="rounded-2xl bg-brand-500 border-2 border-brand-600 p-8 text-center animate-slide-up delay-200 relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-accent-500 text-white text-xs font-bold uppercase tracking-wider px-4 py-1 rounded-full">That's us →</div>
          <div class="text-4xl mb-4">🎉</div>
          <h3 class="text-lg font-bold text-surface-900 font-display mb-2">Zestiq</h3>
          <p class="text-surface-900/70 text-base leading-relaxed">Every ingredient, listed. Plant-based formulas that actually work. Labels that make you smile, not squint.</p>
        </div>
        <div class="rounded-2xl bg-surface-100 border border-surface-200 p-8 text-center animate-slide-up delay-300">
          <div class="text-4xl mb-4">😵</div>
          <h3 class="text-lg font-bold text-surface-900 font-display mb-2">"Natural" Brands</h3>
          <p class="text-surface-800/60 text-base leading-relaxed">Earthy packaging, weak formulas. Smells like someone's cleaning with herbs. Leaves residue. Expensive.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       FEATURES GRID
  ════════════════════════════════════════════════════ -->
  <section id="shop" class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 animate-slide-up">
        <p class="text-sm font-semibold uppercase tracking-widest text-accent-500 mb-4">Why Zestiq Works</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight text-surface-900 font-display leading-tight">
          Bold on grime.<br/>Kind to everything else.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">

        <!-- Feature 1 -->
        <div class="group rounded-2xl border-2 border-surface-200 hover:border-brand-500 bg-surface-50 p-7 transition-colors duration-150 animate-slide-up delay-100">
          <div class="w-12 h-12 rounded-xl bg-brand-500 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-surface-900" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.955 11.955 0 003 10c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.249-8.25-3.286z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-surface-900 font-display mb-2">Full Ingredient Truth</h3>
          <p class="text-surface-800/60 text-base leading-relaxed">Every ingredient, every bottle, always. If we can't explain it in plain English, it's not in there.</p>
        </div>

        <!-- Feature 2 -->
        <div class="group rounded-2xl border-2 border-surface-200 hover:border-accent-500 bg-surface-50 p-7 transition-colors duration-150 animate-slide-up delay-200">
          <div class="w-12 h-12 rounded-xl bg-accent-500 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-surface-900 font-display mb-2">Actually Cleans Stuff</h3>
          <p class="text-surface-800/60 text-base leading-relaxed">Plant-based doesn't mean weak. Our formulas cut through grease, soap scum, and mystery gunk — fast.</p>
        </div>

        <!-- Feature 3 -->
        <div class="group rounded-2xl border-2 border-surface-200 hover:border-green-500 bg-surface-50 p-7 transition-colors duration-150 animate-slide-up delay-300">
          <div class="w-12 h-12 rounded-xl bg-green-500 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-surface-900 font-display mb-2">Safe for Kids & Pets</h3>
          <p class="text-surface-800/60 text-base leading-relaxed">No hormone disruptors, no synthetic fragrances, no VOCs. Scrub the bathtub right before the kids get in.</p>
        </div>

        <!-- Feature 4 -->
        <div class="group rounded-2xl border-2 border-surface-200 hover:border-brand-500 bg-surface-50 p-7 transition-colors duration-150 animate-slide-up delay-400">
          <div class="w-12 h-12 rounded-xl bg-surface-900 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-brand-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-surface-900 font-display mb-2">Looks Good on the Counter</h3>
          <p class="text-surface-800/60 text-base leading-relaxed">Minimalist design, bold colors. You'll actually want to leave these out instead of hiding them under the sink.</p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       HOW IT WORKS
  ════════════════════════════════════════════════════ -->
  <section id="how-it-works" class="py-20 md:py-28 bg-brand-500">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 animate-slide-up">
        <p class="text-sm font-semibold uppercase tracking-widest text-surface-900/60 mb-4">Simple by Design</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight text-surface-900 font-display leading-tight">
          Switching is<br/>embarrassingly easy.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <!-- connector line (desktop) -->
        <div class="hidden md:block absolute top-12 left-1/4 right-1/4 h-0.5 bg-surface-900/20"></div>

        <!-- Step 1 -->
        <div class="text-center animate-slide-up delay-100">
          <div class="w-24 h-24 rounded-full bg-surface-900 text-brand-500 flex items-center justify-center text-3xl font-extrabold font-display mx-auto mb-6 relative z-10">
            01
          </div>
          <h3 class="text-xl font-bold text-surface-900 font-display mb-3">Pick Your Products</h3>
          <p class="text-surface-900/65 text-base leading-relaxed">Browse our line of kitchen, bathroom, and all-purpose cleaners. Read every ingredient before you buy — we insist.</p>
        </div>

        <!-- Step 2 -->
        <div class="text-center animate-slide-up delay-200">
          <div class="w-24 h-24 rounded-full bg-accent-500 text-white flex items-center justify-center text-3xl font-extrabold font-display mx-auto mb-6 relative z-10">
            02
          </div>
          <h3 class="text-xl font-bold text-surface-900 font-display mb-3">We Ship Fast</h3>
          <p class="text-surface-900/65 text-base leading-relaxed">Orders ship within 24 hours. Free shipping over $35. Arrives in minimal, recyclable packaging — no foam peanuts.</p>
        </div>

        <!-- Step 3 -->
        <div class="text-center animate-slide-up delay-300">
          <div class="w-24 h-24 rounded-full bg-green-500 text-white flex items-center justify-center text-3xl font-extrabold font-display mx-auto mb-6 relative z-10">
            03
          </div>
          <h3 class="text-xl font-bold text-surface-900 font-display mb-3">Clean Without Worry</h3>
          <p class="text-surface-900/65 text-base leading-relaxed">Spray, scrub, rinse. That's it. No fumes to ventilate, no gloves required, no wondering what's soaking into your counter.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       TESTIMONIALS
  ════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14 animate-slide-up">
        <p class="text-sm font-semibold uppercase tracking-widest text-green-500 mb-4">Real Customers</p>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-surface-900 font-display">
          40,000 homes switched.<br/>None went back.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl border border-surface-200 p-8 animate-slide-up delay-100">
          <div class="flex items-center gap-1 mb-4">
            <span class="text-accent-500 text-lg">★★★★★</span>
          </div>
          <p class="text-surface-800/70 text-base leading-relaxed mb-6">"I have a toddler and two cats. I was terrified of every cleaner I used. Zestiq let me read every ingredient — and for once I recognized all of them. Game changer."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-brand-500 flex items-center justify-center font-bold text-surface-900 text-sm font-display">MK</div>
            <div>
              <p class="text-sm font-semibold text-surface-900">Maya K.</p>
              <p class="text-xs text-surface-800/50">Portland, OR · Verified buyer</p>
            </div>
          </div>
        </div>

        <div class="bg-accent-500 rounded-2xl p-8 animate-slide-up delay-200">
          <div class="flex items-center gap-1 mb-4">
            <span class="text-white text-lg">★★★★★</span>
          </div>
          <p class="text-white/85 text-base leading-relaxed mb-6">"Finally a cleaning brand that doesn't treat me like I don't care about what's in the bottle. The all-purpose cleaner got permanent marker off my kitchen table. I was shocked."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center font-bold text-accent-500 text-sm font-display">JR</div>
            <div>
              <p class="text-sm font-semibold text-white">Jorge R.</p>
              <p class="text-xs text-white/60">Austin, TX · Verified buyer</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-surface-200 p-8 animate-slide-up delay-300">
          <div class="flex items-center gap-1 mb-4">
            <span class="text-accent-500 text-lg">★★★★★</span>
          </div>
          <p class="text-surface-800/70 text-base leading-relaxed mb-6">"I keep the bottles on my open shelving because they're so beautiful. People ask if they're decoration. I tell them no — they're the only cleaners I'll ever use."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-green-500 flex items-center justify-center font-bold text-white text-sm font-display">AL</div>
            <div>
              <p class="text-sm font-semibold text-surface-900">Anika L.</p>
              <p class="text-xs text-surface-800/50">Brooklyn, NY · Verified buyer</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       INGREDIENT PROMISE CALLOUT
  ════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-24 bg-surface-900">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-slide-up">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-500 mb-5">The Zestiq Promise</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight text-white font-display leading-tight mb-6">
        We list what's in every bottle.<br/>
        <span class="text-brand-500">No exceptions. No fine print.</span>
      </h2>
      <p class="text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        No "fragrance" catch-alls. No proprietary blends hiding sketchy chemicals. Every ingredient has a name, a source, and a reason it's there. That's the deal — and it always will be.
      </p>

      <div class="mt-12 grid sm:grid-cols-3 gap-4 max-w-3xl mx-auto">
        <div class="flex flex-col items-center gap-2 bg-white/5 border border-white/10 rounded-2xl px-6 py-6">
          <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.893 13.393l-1.135-1.135a2.252 2.252 0 01-.421-.585l-1.08-2.16a.414.414 0 00-.663-.107.827.827 0 01-.812.21l-1.273-.363a.89.89 0 00-.738 1.595l.587.39c.59.395.674 1.23.172 1.732l-.2.2c-.212.212-.33.498-.33.796v.41c0 .409-.11.809-.32 1.158l-1.315 2.191a2.11 2.11 0 01-1.81 1.025 1.055 1.055 0 01-1.055-1.055v-1.172c0-.92-.56-1.747-1.414-2.089l-.655-.261a2.25 2.25 0 01-1.383-2.46l.007-.042a2.25 2.25 0 01.29-.787l.09-.15a2.25 2.25 0 012.37-1.048l1.178.236a1.125 1.125 0 001.302-.795l.208-.73a1.125 1.125 0 00-.578-1.315l-.665-.332-.091.091a2.25 2.25 0 01-1.591.659h-.18c-.249 0-.487.1-.662.274a.931.931 0 01-1.458-1.137l1.279-2.132"/>
          </svg>
          <p class="text-white font-semibold font-display text-sm uppercase tracking-wide">No Synthetics</p>
          <p class="text-white/50 text-xs text-center">Zero synthetic fragrances or dyes</p>
        </div>
        <div class="flex flex-col items-center gap-2 bg-white/5 border border-white/10 rounded-2xl px-6 py-6">
          <svg class="w-8 h-8 text-brand-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.955 11.955 0 003 10c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.249-8.25-3.286z"/>
          </svg>
          <p class="text-white font-semibold font-display text-sm uppercase tracking-wide">Third-Party Tested</p>
          <p class="text-white/50 text-xs text-center">Independent lab certification on every batch</p>
        </div>
        <div class="flex flex-col items-center gap-2 bg-white/5 border border-white/10 rounded-2xl px-6 py-6">
          <svg class="w-8 h-8 text-accent-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
